---
interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

const navItems = [
  {
    href: '/',
    label: 'Home',
    active: currentPath === '/',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/></svg>',
  },
  {
    href: '/blog',
    label: 'Blog',
    active: currentPath.startsWith('/blog'),
    icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/></svg>',
  },
  {
    href: '/projects',
    label: 'Projects',
    active: currentPath.startsWith('/projects'),
    icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z"/></svg>',
  },
  {
    href: '/about',
    label: 'About',
    active: currentPath.startsWith('/about'),
    icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/></svg>',
  },
  {
    href: '/uses',
    label: 'Uses',
    active: currentPath.startsWith('/uses'),
    icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7 2a1 1 0 00-.707 1.707L7 4.414v3.758a1 1 0 01-.293.707l-4 4C.817 14.769 2.156 18 4.828 18h10.344c2.672 0 4.011-3.231 2.122-5.121l-4-4A1 1 0 0113 8.172V4.414l.707-.707A1 1 0 0013 2H7zm2 6.172V4h2v4.172a3 3 0 00.879 2.12l1.027 1.028a4 4 0 00-2.171.102l-.47.156a4 4 0 01-2.53 0l-.563-.187a1.993 1.993 0 00-.114-.035l1.063-1.063A3 3 0 009 8.172z" clip-rule="evenodd"/></svg>',
  },
];
---

<nav class="nav-rail">
  <div class="nav-section nav-top">
    {navItems.map(item => (
      <a href={item.href} class:list={['nav-item', { active: item.active }]}>
        <span class="nav-icon" set:html={item.icon} />
        <span class="nav-label">{item.label}</span>
      </a>
    ))}
  </div>

  <div class="nav-section nav-bottom">
    <a
      href="https://github.com/Jhong098"
      target="_blank"
      rel="noopener noreferrer"
      class="nav-item"
    >
      <span class="nav-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
      </span>
      <span class="nav-label">GitHub</span>
    </a>
  </div>
</nav>

<style>
  .nav-rail {
    width: 44px;
    transition: width 200ms ease;
    background: var(--bg-surface);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    padding: 6px 0;
    overflow: hidden;
    flex-shrink: 0;
  }

  .nav-rail:hover {
    width: 180px;
  }

  .nav-section {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 0 5px;
  }

  .nav-top {
    flex: 1;
  }

  .nav-bottom {
    border-top: 1px solid var(--border);
    padding-top: 6px;
    margin-top: 6px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 7px;
    border-radius: 6px;
    color: var(--fg-6);
    text-decoration: none;
    transition: color 150ms, background-color 150ms;
    font-size: 0.8125rem;
    white-space: nowrap;
    min-height: 32px;
  }

  .nav-item:hover {
    color: var(--fg-4);
    background-color: var(--item-hover);
  }

  .nav-item.active {
    color: var(--accent);
    background-color: var(--accent-subtle);
  }

  .nav-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav-icon svg {
    width: 16px;
    height: 16px;
  }

  .nav-label {
    opacity: 0;
    transition: opacity 120ms 60ms;
    font-family: var(--font-sans);
  }

  .nav-rail:hover .nav-label {
    opacity: 1;
  }
</style>
