---
import { getCollection, render } from 'astro:content';
import { readFileSync } from 'node:fs';
import path from 'node:path';
import EditorLayout from '@layouts/EditorLayout.astro';
import SourceDrawer from '@components/blog/SourceDrawer';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.status === 'published');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const rawMdx = readFileSync(
  path.join(process.cwd(), 'src/content/blog', `${post.id}.mdx`),
  'utf-8'
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<EditorLayout
  title={post.data.title}
  description={post.data.description}
  path={`~/blog/${post.id}`}
>
  <article class="page-content">
    <header class="post-header">
      <div class="post-meta-row">
        <div class="tags">
          {post.data.tags.map(tag => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
        <SourceDrawer client:load rawMdx={rawMdx} />
      </div>
      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-date">{formatDate(post.data.date)}</p>
    </header>

    <div class="prose-content">
      <Content />
    </div>

    <footer class="post-footer">
      <a href="/blog" class="back-link">← back to blog</a>
    </footer>
  </article>
</EditorLayout>

<style>
  .page-content {
    max-width: 680px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
  }

  .post-header {
    margin-bottom: 2.5rem;
  }

  .post-meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--fg-6);
    padding: 2px 8px;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .post-title {
    font-size: 1.625rem;
    font-weight: 600;
    color: var(--fg-1);
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--fg-6);
  }

  .post-footer {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--fg-6);
    text-decoration: none;
    transition: color 120ms;
  }

  .back-link:hover {
    color: var(--accent);
  }
</style>
