---
import EditorLayout from '@layouts/EditorLayout.astro';

const gear: Record<string, string[]> = {
  'Computer / Office': [
    '16" MacBook Pro (2019)',
    'Keychron K3 Optical (Brown switches)',
    'Logitech MX Master 3',
  ],
  Coding: [
    'Editor: VSCode',
    'Theme: Atom One Dark',
    'Terminal: iTerm / oh-my-zsh',
  ],
  Photography: [
    'Fujifilm X-T30 (15–45mm)',
  ],
  Music: [
    'Bose QC-35 II',
  ],
  Gaming: [
    'Nintendo Switch',
    'Oculus Quest 2',
  ],
};
---

<EditorLayout title="Uses" path="~/uses">
  <div class="page-content prose-content">
    <p class="file-label">~/uses/index.md</p>
    <h1>Uses</h1>
    <p>Hardware and software I use day-to-day.</p>

    {Object.entries(gear).map(([category, items]) => (
      <div class="gear-section">
        <h3>{category}</h3>
        <ul>
          {items.map(item => <li>{item}</li>)}
        </ul>
      </div>
    ))}
  </div>
</EditorLayout>

<style>
  .page-content {
    max-width: 640px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
  }

  .file-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--fg-6);
    margin-bottom: 1.25rem;
  }

  .gear-section {
    margin-bottom: 0.5rem;
  }
</style>
