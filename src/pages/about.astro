---
import EditorLayout from '@layouts/EditorLayout.astro';

const experience = [
  {
    company: 'AWS',
    role: 'SDE',
    period: '2021 — present',
    desc: 'Building serverless systems and LLM-powered evaluation infrastructure for Amazon Connect Contact Lens.',
  },
  {
    company: 'AWS',
    role: 'SDE Intern',
    period: '2020',
    desc: 'Designed a scalable fault-tolerant backend monitoring system in Node.js and TypeScript for Contact Lens.',
  },
  {
    company: 'Canoo',
    role: 'Software Tools Intern',
    period: '2019',
    desc: 'Built a software release management tool in React, TypeScript, Python, and Flask for 10+ vehicle components.',
  },
  {
    company: 'Hack the North',
    role: 'Organizer',
    period: '2019',
    desc: 'Built web experiences with React and TypeScript for one of the world\'s largest hackathons — 30k visitors, 3M req/month.',
  },
  {
    company: 'StackAdapt',
    role: 'SWE Intern',
    period: '2019',
    desc: 'Implemented customization features on an ad platform managing 3000+ campaigns with Ruby on Rails, React, and Redux.',
  },
  {
    company: 'Monogram',
    role: 'Software Developer Intern',
    period: '2018',
    desc: 'Optimized performance and size for a Qt application in C++ and photo-editing software plugins.',
  },
];

const stack: Record<string, string[]> = {
  Languages: ['TypeScript', 'Python', 'Go'],
  Frontend: ['React', 'Astro', 'Tailwind CSS'],
  Backend: ['AWS Lambda', 'DynamoDB', 'SQS/SNS'],
  Tools: ['Git', 'Docker', 'Terraform'],
};
---

<EditorLayout title="About" path="~/about">
  <div class="page-content prose-content">
    <p class="file-label">~/about/index.md</p>
    <h1>About</h1>

    <p>
      Software engineer based in Vancouver. I care about systems that are fast,
      observable, and pleasant to maintain. I like TypeScript, clean APIs,
      and tools that respect your time.
    </p>

    <h3>Experience</h3>
    <div class="experience-list">
      {experience.map(e => (
        <div class="exp-item">
          <div class="exp-meta">
            <span class="exp-company">{e.company}</span>
            <span class="exp-period">{e.period}</span>
          </div>
          <div class="exp-body">
            <span class="exp-role">{e.role}</span>
            <p class="exp-desc">{e.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <h3>Stack</h3>
    <div class="stack-grid">
      {Object.entries(stack).map(([cat, items]) => (
        <div class="stack-group">
          <p class="stack-cat">{cat}</p>
          <div class="stack-tags">
            {items.map(item => (
              <span class="stack-tag">{item}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <h3>Education</h3>
    <p>
      BASc Computer Engineering — University of Waterloo, class of 2021.
    </p>

  </div>
</EditorLayout>

<style>
  .page-content {
    max-width: 640px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
  }

  .file-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--fg-6);
    margin-bottom: 1.25rem;
  }

  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .exp-item {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .exp-meta {
    min-width: 120px;
    flex-shrink: 0;
  }

  .exp-company {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--fg-2);
  }

  .exp-period {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--fg-6);
    margin-top: 2px;
  }

  .exp-role {
    display: block;
    font-size: 0.8125rem;
    color: var(--fg-4);
    margin-bottom: 2px;
  }

  .exp-desc {
    font-size: 0.8125rem;
    color: var(--fg-5);
    margin: 0;
  }

  .stack-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .stack-cat {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--fg-6);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 6px;
  }

  .stack-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .stack-tag {
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--bg-elevated);
    border: 1px solid var(--border-muted);
    color: var(--fg-4);
    font-family: var(--font-mono);
    font-size: 0.7rem;
  }
</style>
